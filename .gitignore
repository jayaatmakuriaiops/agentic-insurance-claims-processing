# Local .terraform directories
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!terraform.tfvars.example

# Crash log files
crash.log
crash.*.log

# Ignore .terraformrc file with sensitive credentials
.terraformrc

# Terraform Cloud/Enterprise credentials
*.tfrc
.terraformrc.hcl

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Backup files
*.backup
*.bak
